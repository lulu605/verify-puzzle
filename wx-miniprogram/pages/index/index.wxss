.cover{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:10;background:linear-gradient(135deg,#0a0e27 0%,#1a1040 50%,#0a0e27 100%)}
.cover-stars{position:absolute;top:0;left:0;width:100%;height:100%;overflow:hidden;pointer-events:none}
.star{position:absolute;width:2px;height:2px;background:#fff;border-radius:50%;animation:twinkle 2s infinite alternate}
@keyframes twinkle{0%{opacity:0.2}100%{opacity:1}}
.cover-title{font-size:28px;font-weight:bold;color:#64ffda;letter-spacing:4px;text-align:center;margin-bottom:8px;z-index:1}
.cover-subtitle{font-size:14px;color:#8892b0;letter-spacing:2px;margin-bottom:40px;z-index:1}
.cover-btn{padding:14px 48px;background:transparent;border:2px solid #64ffda;border-radius:8px;color:#64ffda;font-size:18px;letter-spacing:2px;z-index:1;line-height:1}
.cover-btn::after{border:none}
